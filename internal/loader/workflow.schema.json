{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w7s.io/workflow.schema.json",
  "title": "Workflow",
  "type": "object",
  "required": ["id", "name", "version", "agents", "steps"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "workspace": {
            "type": "object",
            "properties": {
              "files": {
                "type": "object",
                "additionalProperties": { "type": "string" }
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "agent", "input"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "agent": { "type": "string", "minLength": 1 },
          "input": { "type": "string" },
          "expects": { "type": "string" },
          "extract": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "requires_output": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "on_fail": {
            "type": "object",
            "properties": {
              "retry_step": { "type": "string" },
              "feedback_var": { "type": "string" },
              "max_retries": { "type": "integer", "minimum": 0 },
              "on_exhausted": {
                "type": "object",
                "required": ["escalate_to"],
                "properties": {
                  "escalate_to": { "type": "string" }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
